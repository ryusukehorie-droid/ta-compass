# Notion Integration Token
# 1. Go to https://www.notion.so/my-integrations
# 2. Create a new Internal Integration
# 3. Copy the "Internal Integration Secret" here
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (for AI auto-fill in Knowledge DB)
# Get your key at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: The Notion page ID where the database will be created.
# If omitted, the app picks the first page your integration can access.
# To find a page ID: open the page in Notion, copy the URL,
# the last 32-char hex string (with or without dashes) is the ID.
# NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
